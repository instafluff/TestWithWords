{
  "name": "testwithwords",
  "version": "0.1.1",
  "description": "AI-powered UI testing — describe the test in plain English, the AI does the rest",
  "type": "module",
  "bin": {
    "tww": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/",
    "!dist/tests/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc && node dist/cli.js",
    "test": "tsc && node --test dist/tests/**/*.test.js",
    "prepublishOnly": "npm run build",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": [
    "testing",
    "ai",
    "browser",
    "automation",
    "natural-language",
    "playwright",
    "e2e",
    "end-to-end",
    "ui-testing",
    "llm"
  ],
  "author": "Instafluff",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/instafluff/TestWithWords.git"
  },
  "homepage": "https://testwithwords.com",
  "bugs": {
    "url": "https://github.com/instafluff/TestWithWords/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright-core": "^1.42.0",
    "openai": "^4.28.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.11.0"
  }
}
